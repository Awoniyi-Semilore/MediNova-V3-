# Create placeholder icons
import os
os.makedirs("public/icons", exist_ok=True)

# Create a simple SVG icon as placeholder
icon_svg = '''<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0ea5e9;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#22c55e;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="192" height="192" rx="48" fill="url(#grad)"/>
  <text x="96" y="120" font-family="Arial, sans-serif" font-size="80" font-weight="bold" fill="white" text-anchor="middle">M</text>
</svg>
'''

with open("public/icons/pwa-192x192.svg", "w") as f:
    f.write(icon_svg)

with open("public/icons/pwa-512x512.svg", "w") as f:
    f.write(icon_svg.replace('192', '512').replace('80', '200'))

print("✅ Asset links and icons created")
